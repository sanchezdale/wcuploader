{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "labels": [
    "dependencies"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "description": "Automerge GitHub Actions patch and minor updates",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge safe dev dependency patch updates",
      "matchDepTypes": [
        "devDependencies"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge low-risk security tooling",
      "matchPackageNames": [
        "trufflesecurity/trufflehog",
        "zizmorcore/zizmor-action"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Manual review for major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "dependencyDashboardApproval": true
    },
    {
      "description": "Manual review for risky frontend/runtime upgrades",
      "matchPackageNames": [
        "vite",
        "typescript",
        "svelte",
        "react",
        "react-dom",
        "@vitejs/plugin-react",
        "@sveltejs/vite-plugin-svelte",
        "wrangler",
        "modernc.org/sqlite",
        "github.com/labstack/echo/v4",
        "github.com/labstack/echo/v5"
      ],
      "automerge": false,
      "dependencyDashboardApproval": true
    },
    {
      "description": "Manual review for Docker/base image updates",
      "matchDatasources": [
        "docker"
      ],
      "automerge": false,
      "dependencyDashboardApproval": true
    }
  ]
}
